generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
  binaryTargets   = ["debian-openssl-3.0.x", "linux-arm64-openssl-3.0.x", "native"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Access {
  alias         String?
  createdAt     DateTime           @default(now())
  granteeUser   User?              @relation("accessGet", fields: [granteeUserId], onDelete: Cascade, references: [id])
  granteeUserId String?
  id            String             @id @default(uuid())
  permissions   AccessPermission[] @default([READ_RESTRICTED])
  updatedAt     DateTime           @updatedAt
  userId        String
  user          User               @relation("accessGive", fields: [userId], onDelete: Cascade, references: [id])

  @@index([alias])
  @@index([granteeUserId])
  @@index([userId])
}

model Account {
  activities Order[]
  balance    Float            @default(0)
  balances   AccountBalance[]
  comment    String?
  createdAt  DateTime         @default(now())
  currency   String?
  id         String           @default(uuid())
  isExcluded Boolean          @default(false)
  name       String?
  platform   Platform?        @relation(fields: [platformId], references: [id])
  platformId String?
  updatedAt  DateTime         @updatedAt
  user       User             @relation(fields: [userId], onDelete: Cascade, references: [id])
  userId     String

  @@id([id, userId])
  @@index([currency])
  @@index([id])
  @@index([isExcluded])
  @@index([name])
  @@index([userId])
}

model AccountBalance {
  account   Account  @relation(fields: [accountId, userId], onDelete: Cascade, references: [id, userId])
  accountId String
  createdAt DateTime @default(now())
  date      DateTime @default(now())
  id        String   @id @default(uuid())
  updatedAt DateTime @updatedAt
  userId    String
  value     Float

  @@unique([accountId, date])
  @@index([accountId])
  @@index([date])
}

model Analytics {
  activityCount                       Int      @default(0)
  country                             String?
  dataProviderGhostfolioDailyRequests Int      @default(0)
  lastRequestAt                       DateTime @default(now())
  updatedAt                           DateTime @updatedAt
  user                                User     @relation(fields: [userId], onDelete: Cascade, references: [id])
  userId                              String   @id

  @@index([lastRequestAt])
  @@index([updatedAt])
}

model ApiKey {
  createdAt DateTime @default(now())
  hashedKey String   @unique
  id        String   @id @default(uuid())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], onDelete: Cascade, references: [id])
  userId    String

  @@index([userId])
}

model AuthDevice {
  createdAt           DateTime @default(now())
  credentialId        Bytes
  credentialPublicKey Bytes
  counter             Int
  id                  String   @id @default(uuid())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], onDelete: Cascade, references: [id])
  userId              String

  @@index([userId])
}

model MarketData {
  createdAt   DateTime        @default(now())
  dataSource  DataSource
  date        DateTime
  id          String          @id @default(uuid())
  marketPrice Float
  state       MarketDataState @default(CLOSE)
  symbol      String

  @@unique([dataSource, date, symbol])
  @@index([dataSource])
  @@index([dataSource, symbol])
  @@index([date])
  @@index([marketPrice])
  @@index([state])
  @@index([symbol])
}

model Order {
  account         Account?      @relation(fields: [accountId, accountUserId], references: [id, userId])
  accountId       String?
  accountUserId   String?
  comment         String?
  createdAt       DateTime      @default(now())
  currency        String?
  date            DateTime
  fee             Float
  id              String        @id @default(uuid())
  isDraft         Boolean       @default(false)
  quantity        Float
  symbolProfileId String
  tags            Tag[]
  type            Type
  unitPrice       Float
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], onDelete: Cascade, references: [id])
  userId          String
  SymbolProfile   SymbolProfile @relation(fields: [symbolProfileId], references: [id])

  @@index([accountId])
  @@index([date])
  @@index([isDraft])
  @@index([userId])
}

model Platform {
  accounts Account[]
  id       String    @id @default(uuid())
  name     String?
  url      String    @unique

  @@index([name])
}

model Property {
  key   String @id
  value String
}

model Settings {
  settings  Json?
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], onDelete: Cascade, references: [id])
  userId    String   @id
}

model SymbolProfile {
  activities             Order[]
  assetClass             AssetClass?
  assetSubClass          AssetSubClass?
  comment                String?
  countries              Json?
  createdAt              DateTime                @default(now())
  currency               String
  cusip                  String?
  dataSource             DataSource
  figi                   String?
  figiComposite          String?
  figiShareClass         String?
  holdings               Json?                   @default("[]")
  id                     String                  @id @default(uuid())
  isActive               Boolean                 @default(true)
  isin                   String?
  name                   String?
  updatedAt              DateTime                @updatedAt
  scraperConfiguration   Json?
  sectors                Json?
  symbol                 String
  symbolMapping          Json?
  url                    String?
  user                   User?                   @relation(fields: [userId], onDelete: Cascade, references: [id])
  userId                 String?
  watchedBy              User[]                  @relation("UserWatchlist")
  SymbolProfileOverrides SymbolProfileOverrides?

  @@unique([dataSource, symbol])
  @@index([assetClass])
  @@index([currency])
  @@index([cusip])
  @@index([dataSource])
  @@index([isActive])
  @@index([isin])
  @@index([name])
  @@index([symbol])
}

model SymbolProfileOverrides {
  assetClass      AssetClass?
  assetSubClass   AssetSubClass?
  countries       Json?          @default("[]")
  holdings        Json?          @default("[]")
  name            String?
  sectors         Json?          @default("[]")
  symbolProfileId String         @id
  updatedAt       DateTime       @updatedAt
  url             String?
  SymbolProfile   SymbolProfile  @relation(fields: [symbolProfileId], onDelete: Cascade, references: [id])
}

model Subscription {
  createdAt DateTime @default(now())
  expiresAt DateTime
  id        String   @id @default(uuid())
  price     Float?
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], onDelete: Cascade, references: [id])
  userId    String

  @@index([userId])
}

model Tag {
  activities Order[]
  id         String  @id @default(uuid())
  name       String
  user       User?   @relation(fields: [userId], onDelete: Cascade, references: [id])
  userId     String?

  @@unique([name, userId])
  @@index([name])
}

model User {
  accessesGet   Access[]        @relation("accessGet")
  accessesGive  Access[]        @relation("accessGive")
  accessToken   String?
  accounts      Account[]
  activities    Order[]
  analytics     Analytics?
  apiKeys       ApiKey[]
  authChallenge String?
  authDevices   AuthDevice[]
  createdAt     DateTime        @default(now())
  id            String          @id @default(uuid())
  provider      Provider        @default(ANONYMOUS)
  role          Role            @default(USER)
  settings      Settings?
  subscriptions Subscription[]
  tags          Tag[]
  thirdPartyId  String?
  updatedAt     DateTime        @updatedAt
  watchlist     SymbolProfile[] @relation("UserWatchlist")
  SymbolProfile SymbolProfile[]

  // TAX SYSTEM RELATIONS
  taxResidency          TaxResidency[]           @relation("UserTaxResidency")
  employmentIncome      TaxEmploymentIncome[]    @relation("UserEmploymentIncome") 
  investmentIncome      TaxInvestmentIncome[]    @relation("UserInvestmentIncome")
  taxWithholdings       TaxWithholding[]         @relation("UserTaxWithholding")
  retirementAccounts    TaxRetirementAccounts[]  @relation("UserRetirementAccounts")
  taxCalculations       TaxCalculation[]         @relation("UserTaxCalculation")
  rsuGrants             TaxRsuGrant[]            @relation("UserRsuGrants")
  rsuVestings           TaxRsuVesting[]          @relation("UserRsuVesting") 
  esppPurchases         TaxEsppPurchase[]        @relation("UserEsppPurchases")

  @@index([accessToken])
  @@index([createdAt])
  @@index([provider])
  @@index([role])
  @@index([thirdPartyId])
}

// =============================================================================
// TAX CALCULATION SYSTEM MODELS
// =============================================================================

// Tax Residency Tracking (calendar days per country)
model TaxResidency {
  id          String   @id @default(uuid())
  userId      String
  year        Int
  country     String   // 'CA', 'US', 'IN' 
  startDate   DateTime
  endDate     DateTime
  days        Int      // calculated field
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation("UserTaxResidency", fields: [userId], onDelete: Cascade, references: [id])
  
  @@unique([userId, year, country, startDate])
  @@index([userId, year])
  @@index([country])
}

// Employment Income Tracking
model TaxEmploymentIncome {
  id              String   @id @default(uuid())
  userId          String
  year            Int
  baseSalary      Float    // Annual base salary in CAD
  bonusPercent    Float?   // Bonus as % of base salary
  bonusAmount     Float?   // Or fixed bonus amount
  currency        String   @default("CAD")
  province        String   @default("ON") // Ontario default
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation("UserEmploymentIncome", fields: [userId], onDelete: Cascade, references: [id])
  
  @@unique([userId, year])
  @@index([userId])
  @@index([year])
}

// RSU Grant Tracking (individual grants with vesting schedules)
model TaxRsuGrant {
  id              String   @id @default(uuid())
  userId          String
  grantDate       DateTime
  grantId         String   // Company grant ID (e.g., "RSU-2024-001")
  totalShares     Int      // Total shares granted
  strikePrice     Float?   // For stock options (RSUs usually $0)
  currency        String   @default("USD") // Usually USD for tech companies
  vestingSchedule Json     // Array of vesting dates and quantities
  status          GrantStatus @default(ACTIVE)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation("UserRsuGrants", fields: [userId], onDelete: Cascade, references: [id])
  vestingEvents   TaxRsuVesting[]
  
  @@unique([userId, grantId])
  @@index([userId])
  @@index([grantDate])
}

// RSU Vesting Events (actual vesting occurrences)
model TaxRsuVesting {
  id              String      @id @default(uuid())
  userId          String
  grantId         String      // Link to TaxRsuGrant
  vestDate        DateTime    // Date shares vested
  sharesVested    Int         // Number of shares that vested
  fmvPerShare     Float       // Fair market value per share (USD)
  totalValueUSD   Float       // Total value in USD
  exchangeRate    Float       // USD to CAD rate on vest date
  totalValueCAD   Float       // Total value in CAD (taxable income)
  taxWithheldUSD  Float?      // US tax withheld
  taxWithheldCAD  Float?      // CAD equivalent of withholding
  isAutoCalculated Boolean    @default(false) // From existing transactions
  orderId         String?     // Link to Order if exists
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  user            User        @relation("UserRsuVesting", fields: [userId], onDelete: Cascade, references: [id])
  grant           TaxRsuGrant @relation(fields: [grantId], references: [grantId])
  
  @@index([userId, vestDate])
  @@index([grantId])
}

// ESPP Purchase Events  
model TaxEsppPurchase {
  id                String   @id @default(uuid())
  userId            String
  purchaseDate      DateTime
  purchasePeriodEnd DateTime // End of purchase period
  sharesPurchased   Int
  fmvPerShare       Float    // Fair market value on purchase date
  purchasePrice     Float    // Discounted purchase price
  discountPercent   Float    // Discount percentage (e.g., 15%)
  discountAmountUSD Float    // Taxable discount amount
  exchangeRate      Float    // USD to CAD rate
  discountAmountCAD Float    // Taxable amount in CAD
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation("UserEsppPurchases", fields: [userId], onDelete: Cascade, references: [id])
  
  @@index([userId, purchaseDate])
}

// Investment Income (calculated from existing transactions + manual entries)
model TaxInvestmentIncome {
  id              String          @id @default(uuid())
  userId          String
  year            Int
  type            InvestmentIncomeType
  amount          Float           // Amount in CAD
  amountOriginal  Float?          // Original currency amount
  currency        String?         // Original currency
  exchangeRate    Float?          // CAD conversion rate
  sourceCountry   String?         // 'CA', 'US', 'IN' for tax credit calc
  isAutoCalculated Boolean        @default(false) // true if from transactions
  transactionDate DateTime?       // For currency conversion
  orderId         String?         // Link to original transaction if auto-calc
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  user            User            @relation("UserInvestmentIncome", fields: [userId], onDelete: Cascade, references: [id])
  
  @@index([userId, year])
  @@index([type])
  @@index([sourceCountry])
}

// Tax Withholdings (track taxes already paid)
model TaxWithholding {
  id            String   @id @default(uuid())
  userId        String
  year          Int
  country       String   // Country where tax was withheld
  type          WithholdingType
  amount        Float    // Amount withheld in CAD
  amountOriginal Float?  // Original currency
  currency      String?  // Original currency
  exchangeRate  Float?   // Conversion rate used
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation("UserTaxWithholding", fields: [userId], onDelete: Cascade, references: [id])
  
  @@index([userId, year])
  @@index([country])
  @@index([type])
}

// RRSP/TFSA Contribution Room Tracking
model TaxRetirementAccounts {
  id                    String   @id @default(uuid())
  userId                String
  year                  Int
  rrspeRoomStart        Float    @default(0) // Room at start of year
  rrspeRoomEarned       Float    @default(0) // 18% of prior year income
  rrspeRoomCarriedForward Float  @default(0) // Unused room from prior years
  rrspeContributed      Float    @default(0) // Contributions made this year
  rrspeEmployerMatching Float    @default(0) // Employer matching
  rrspeRoomRemaining    Float    @default(0) // Calculated remaining room
  tfsaRoomStart         Float    @default(0) // Room at start of year
  tfsaRoomAnnual        Float    @default(7000) // Annual TFSA limit
  tfsaRoomCarriedForward Float   @default(0) // Unused room
  tfsaContributed       Float    @default(0) // Contributions this year
  tfsaWithdrawn         Float    @default(0) // Withdrawals (add to next year room)
  tfsaRoomRemaining     Float    @default(0) // Calculated remaining room
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation("UserRetirementAccounts", fields: [userId], onDelete: Cascade, references: [id])
  
  @@unique([userId, year])
  @@index([userId])
}

// Tax Calculations (final computed results)
model TaxCalculation {
  id                   String   @id @default(uuid())
  userId               String
  year                 Int
  province             String   @default("ON")
  totalEmploymentIncome Float   @default(0)
  totalInvestmentIncome Float   @default(0)
  totalCapitalGains    Float    @default(0) // 50% inclusion
  totalTaxableIncome   Float    @default(0)
  federalTax           Float    @default(0)
  provincialTax        Float    @default(0)
  totalTaxOwed         Float    @default(0)
  totalWithholdings    Float    @default(0)
  estimatedRefund      Float    @default(0) // or amount owing
  calculatedAt         DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation("UserTaxCalculation", fields: [userId], onDelete: Cascade, references: [id])
  
  @@unique([userId, year])
  @@index([userId])
  @@index([year])
}

// Exchange Rate Cache (for currency conversions)
model ExchangeRate {
  id       String   @id @default(uuid())
  date     DateTime
  fromCurrency String // USD, EUR, etc.
  toCurrency   String // CAD
  rate     Float
  source   String   @default("BANK_OF_CANADA") // Rate source
  createdAt DateTime @default(now())
  
  @@unique([date, fromCurrency, toCurrency])
  @@index([date])
  @@index([fromCurrency, toCurrency])
}

// =============================================================================
// EXISTING ENUMS
// =============================================================================

enum AccessPermission {
  READ
  READ_RESTRICTED
}

enum AssetClass {
  ALTERNATIVE_INVESTMENT
  COMMODITY
  EQUITY
  FIXED_INCOME
  LIQUIDITY
  REAL_ESTATE
}

enum AssetSubClass {
  BOND
  CASH
  COLLECTIBLE
  COMMODITY
  CRYPTOCURRENCY
  ETF
  MUTUALFUND
  PRECIOUS_METAL
  PRIVATE_EQUITY
  STOCK
}

enum DataSource {
  ALPHA_VANTAGE
  COINGECKO
  EOD_HISTORICAL_DATA
  FINANCIAL_MODELING_PREP
  GHOSTFOLIO
  GOOGLE_SHEETS
  MANUAL
  RAPID_API
  YAHOO
}

enum MarketDataState {
  CLOSE
  INTRADAY
}

enum Provider {
  ANONYMOUS
  GOOGLE
  INTERNET_IDENTITY
}

enum Role {
  ADMIN
  DEMO
  INACTIVE
  USER
}

enum Type {
  BUY
  DIVIDEND
  FEE
  INTEREST
  ITEM
  LIABILITY
  SELL
}

enum ViewMode {
  DEFAULT
  ZEN
}

// =============================================================================
// TAX SYSTEM ENUMS
// =============================================================================

enum InvestmentIncomeType {
  DIVIDEND_ELIGIBLE     // Canadian eligible dividends
  DIVIDEND_NON_ELIGIBLE // Canadian non-eligible dividends  
  DIVIDEND_FOREIGN      // Foreign dividends
  INTEREST              // Interest income
  CAPITAL_GAINS         // Capital gains (50% taxable)
  CAPITAL_LOSSES        // Capital losses
}

enum WithholdingType {
  INCOME_TAX             // Regular income tax withheld
  RSU_WITHHOLDING        // Tax withheld on RSU vesting
  ESPP_WITHHOLDING       // Tax withheld on ESPP discount
  DIVIDEND_WITHHOLDING   // Foreign dividend withholding
  INTEREST_WITHHOLDING   // Foreign interest withholding
  TDS_FIXED_DEPOSIT      // Indian TDS on Fixed Deposits
  TDS_SAVINGS_ACCOUNT    // Indian TDS on Savings Account Interest
  TDS_SALARY             // Indian TDS on Salary
  TDS_RENT               // Indian TDS on Rent Income
  TDS_PROFESSIONAL_FEES  // Indian TDS on Professional Services
  TDS_OTHER              // Other Indian TDS categories
}

enum GrantStatus {
  ACTIVE     // Grant is active and vesting
  EXPIRED    // Grant expired unvested
  CANCELLED  // Grant was cancelled
  COMPLETED  // All shares have vested
}